{
  "name": "zk-peer-reward-poc",
  "private": true,
  "version": "0.1.0",
  "description": "Proof-of-concept artifacts for ZK-verifiable peer-prediction rewards.",
  "scripts": {
    "generate:v1": "node scripts/generate_v1_vector.js",
    "generate:v2": "node scripts/generate_v2_vector.js",
    "e2e:anvil": "node scripts/run_anvil_e2e.js",
    "e2e:full-maci-reward": "node scripts/run_full_maci_reward_e2e.js",
    "e2e:full-maci-reward:anvil": "FULL_MACI_NETWORK=anvil node scripts/run_full_maci_reward_e2e.js",
    "experiments:reward-data": "node scripts/run_reward_experiments.js",
    "experiments:attack-simulation": "python3 scripts/run_attack_simulation.py",
    "experiments:privacy-audit": "python3 scripts/run_privacy_audit.py",
    "experiments:reward-scaling": "node scripts/run_reward_scaling_experiments.js",
    "experiments:reward-plots": "python3 scripts/plot_reward_experiments.py",
    "experiments:reward": "npm run experiments:reward-data && npm run experiments:privacy-audit && npm run experiments:reward-scaling && npm run experiments:reward-plots",
    "benchmark:reward-layer-scaling": "node scripts/run_reward_layer_scaling_benchmark.js && python3 scripts/plot_reward_layer_scaling.py",
    "benchmark:reward-layer-scaling-plots": "python3 scripts/plot_reward_layer_scaling.py",
    "test:v2:circuit": "node scripts/test_v2_tamper.js",
    "test:reference": "node reference/test_reward_model.js",
    "bench:reference": "node scripts/benchmark_reference.js"
  },
  "devDependencies": {
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6"
  }
}
